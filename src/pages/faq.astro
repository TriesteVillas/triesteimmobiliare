---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';

const owners = [
  { q: 'Davvero 0% di provvigione al venditore?', a: 'Sì. La nostra provvigione è interamente a carico dell\'acquirente. Tu paghi solo se firmi un mandato senza esclusiva e cambi idea — ma nei nostri mandati standard non succede.' },
  { q: 'Quanto dura il mandato?', a: '3 mesi. Rinnovabile solo se vuoi, su richiesta esplicita. Niente vincoli annuali automatici.' },
  { q: 'Quanto costa il marketing fotografico e i tour 3D?', a: 'Inclusi nel mandato. Servizio fotografico professionale, video editoriale, drone dove utile, tour Matterport: tutto a carico nostro.' },
  { q: 'Su quali portali pubblicate?', a: 'Immobiliare.it, Idealista, Casa.it, Wikicasa, sul sito TriesteImmobiliare, sul sito TriesteVillas per gli immobili borderline, e nel pool acquirenti del gruppo.' },
  { q: 'Posso vendere e affittare contemporaneamente?', a: 'Sì, è la strategia "affitta mentre vendi": vedi la pagina dedicata.' },
];

const buyers = [
  { q: 'Lavorate con clienti esteri?', a: 'Sì, abitualmente. Acquirenti austriaci, tedeschi e sloveni sono parte significativa del nostro buyer book. Sito multilingua, documenti tradotti, accompagnamento al notaio.' },
  { q: 'Cos\'è una "ricerca guidata"?', a: 'Un consulente capisce cosa cerchi davvero, filtra il mercato (anche fuori dal nostro portafoglio), organizza visite mirate. Non navighi tu i portali — lo facciamo per te.' },
  { q: 'Posso prenotare un house tour se non vivo a Trieste?', a: 'Sì, è uno dei servizi più richiesti. Una mezza giornata o giornata intera, 3-5 immobili pre-selezionati. Vedi la pagina dedicata.' },
  { q: 'Aiutate sulla parte fiscale e burocratica?', a: 'Sì: codice fiscale, apertura conto, traduzioni documenti, contatti con notai di fiducia. Per la consulenza fiscale ci appoggiamo a commercialisti specializzati.' },
  { q: 'Gestite anche locazioni post-acquisto?', a: 'Sì, tramite TriesteAffitti — il brand sister del gruppo dedicato agli affitti flessibili 1-18 mesi.' },
];
---
<Base
  title="Domande frequenti"
  description="FAQ TriesteImmobiliare: provvigione, mandato, marketing, processo. Risposte dirette su vendita e acquisto."
>
  <Hero
    eyebrow="08 · FAQ"
    title={`Domande<br/><em>frequenti</em>.`}
    lede="Le risposte più chieste su mandati, provvigione, processo. Se non trovi la tua, scrivici."
  />

  <Section pad="lg">
    <Eyebrow num="01">Per chi vende</Eyebrow>
    <h2 style="margin-top: var(--space-2);">Proprietari.</h2>
    <div class="faqs">
      {owners.map((f) => (
        <details class="faq">
          <summary>{f.q}</summary>
          <div class="faq__a"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
  </Section>

  <Section variant="surface" pad="lg">
    <Eyebrow num="02">Per chi compra</Eyebrow>
    <h2 style="margin-top: var(--space-2);">Acquirenti internazionali.</h2>
    <div class="faqs">
      {buyers.map((f) => (
        <details class="faq">
          <summary>{f.q}</summary>
          <div class="faq__a"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
  </Section>
</Base>

<style>
  .faqs { margin-top: var(--space-4); max-width: 56rem; }
  .faq {
    border-bottom: 1px solid var(--c-border);
  }
  .faq summary {
    cursor: pointer;
    list-style: none;
    padding: var(--space-3) 0;
    font-size: var(--fs-lg);
    font-weight: var(--fw-medium);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    transition: color var(--t-fast) var(--ease);
  }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after {
    content: '+';
    font-size: var(--fs-2xl);
    color: var(--c-primary);
    font-weight: var(--fw-light);
    transition: transform var(--t-base) var(--ease);
  }
  .faq[open] summary::after { transform: rotate(45deg); }
  .faq summary:hover { color: var(--c-primary); }
  .faq__a {
    padding: 0 0 var(--space-4) 0;
    max-width: 60ch;
  }
  .faq__a p { font-size: var(--fs-base); color: var(--c-ink-soft); }
</style>
