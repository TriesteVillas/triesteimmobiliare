---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import FormPlaceholder from '../components/FormPlaceholder.astro';

const blocks = [
  { num: '01', title: 'Documenti', items: ['APE valida e coerente', 'Conformità urbanistica', 'Planimetrie catastali', 'Atto di provenienza', 'Visura ipocatastale'] },
  { num: '02', title: 'Condizioni proprietà', items: ['Stato impianti (CIE, conformità)', 'Situazione condominiale', 'Spese arretrate o lavori deliberati', 'Lifting estetico pre-foto'] },
  { num: '03', title: 'Timing e strategia', items: ['Prezzo realistico vs. ambizioso', 'Tempi di mercato per zona/tipologia', 'Calendario pubblicazione e visite', 'Coordinamento con eventuale affitto'] },
];
---
<Base
  title="Check-up pre vendita"
  description="Verifichiamo documenti, condizioni e strategia prima che la tua casa vada sul mercato. Per arrivare al rogito senza sorprese."
>
  <Hero
    eyebrow="06 · Pre-vendita"
    title={`<em>Check-up</em><br/>prima del mercato.`}
    lede="Una casa pronta arriva al rogito. Una casa con sorprese perde mesi, talvolta la vendita. Il check-up risolve tutto prima della pubblicazione."
  />

  <Section pad="lg">
    <div class="grid">
      {blocks.map((b) => (
        <article class="block">
          <Eyebrow num={b.num}>{b.title}</Eyebrow>
          <ul>
            {b.items.map((i) => <li>{i}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </Section>

  <Section variant="surface" pad="lg">
    <FormPlaceholder cta="Richiedi check-up" intro="Compila il modulo: ti contattiamo per fissare una verifica iniziale." />
  </Section>
</Base>

<style>
  .grid { display: grid; grid-template-columns: 1fr; gap: var(--space-5); }
  @media (min-width: 800px) { .grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); } }
  .block ul { margin-top: var(--space-3); display: flex; flex-direction: column; gap: 0.5rem; }
  .block li {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--c-border);
    font-size: var(--fs-base);
    color: var(--c-ink-soft);
  }
  .block li:last-child { border-bottom: none; }
</style>
