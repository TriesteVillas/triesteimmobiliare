---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import FormPlaceholder from '../components/FormPlaceholder.astro';

const stats = [
  { num: '24h', label: 'Contatto dopo la richiesta' },
  { num: '48h', label: 'Sopralluogo concordato' },
  { num: '7gg', label: 'Online sui portali' },
  { num: '3 mesi', label: 'Durata del mandato' },
];

const marketing = [
  { title: 'Servizio fotografico professionale', body: 'Fotografo dedicato, scatti in luce diurna ottimale, post-produzione neutra (no fake HDR).' },
  { title: 'Video editoriale + drone', body: 'Video da 30-60", drone dove utile e regolare. Tour ottimizzato per Instagram, YouTube, portali.' },
  { title: 'Tour virtuale 3D Matterport', body: 'Acquirenti esteri pre-qualificati senza far perdere tempo a nessuno.' },
  { title: 'Pubblicazione multi-portale', body: 'Immobiliare.it, Idealista, Casa.it, Wikicasa, sito TriesteImmobiliare, network di gruppo.' },
];
---
<Base
  title="Vendi casa al 0% di provvigione al venditore"
  description="Vendere casa a Trieste con mandato di 3 mesi, 0% al venditore, marketing professionale e network del gruppo TriesteVillas."
>
  <Hero
    eyebrow="02 · Vendi"
    title={`Vendi casa al <em>0%</em><br/>di provvigione al venditore.`}
    lede="Mandato breve, marketing curato, una sola commissione — a carico dell'acquirente. Niente vincoli annuali, niente costi sorpresa."
  >
    <div style="margin-top: var(--space-4); display: flex; gap: var(--space-2); flex-wrap: wrap;">
      <Button href="/valutazione" variant="primary" size="lg">Richiedi valutazione</Button>
      <Button href="#processo" variant="outline" size="lg">Come funziona</Button>
    </div>
  </Hero>

  <Section variant="surface" pad="md">
    <ul class="stats">
      {stats.map((s) => (
        <li class="stats__item">
          <span class="stats__num">{s.num}</span>
          <span class="stats__label">{s.label}</span>
        </li>
      ))}
    </ul>
  </Section>

  <Section id="processo" pad="lg">
    <Eyebrow num="01">Marketing</Eyebrow>
    <h2 style="margin-top: var(--space-2); max-width: 18ch;">Ogni casa ha il suo servizio editoriale.</h2>
    <div class="grid-2">
      {marketing.map((m) => (
        <div class="card">
          <h3>{m.title}</h3>
          <p>{m.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section variant="surface" pad="lg">
    <div class="split">
      <div>
        <Eyebrow num="02">Network</Eyebrow>
        <h2 style="margin-top: var(--space-2);">Buyer network di gruppo.</h2>
        <p style="margin-top: var(--space-3);">L'immobile entra automaticamente nel pool acquirenti di TriesteVillas (lusso), FriuliVillas e LignanoVillas. Spesso il match arriva prima della pubblicazione pubblica.</p>
      </div>
      <FormPlaceholder cta="Parliamo della tua vendita" intro="Indirizzo, timing, eventuale prezzo target. Ti contattiamo entro 24h." />
    </div>
  </Section>
</Base>

<style>
  .stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
  @media (min-width: 700px) { .stats { grid-template-columns: repeat(4, 1fr); } }
  .stats__item {
    display: flex; flex-direction: column; gap: 0.25rem;
    padding: var(--space-3);
    background: var(--c-bg);
    border-radius: var(--r-md);
  }
  .stats__num { font-size: var(--fs-3xl); font-weight: var(--fw-semibold); color: var(--c-primary); letter-spacing: var(--ls-tight); }
  .stats__label { font-size: var(--fs-sm); color: var(--c-mute); }

  .grid-2 { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-top: var(--space-5); }
  @media (min-width: 800px) { .grid-2 { grid-template-columns: 1fr 1fr; gap: var(--space-5); } }

  .card {
    padding: var(--space-4);
    background: var(--c-surface);
    border-radius: var(--r-md);
    border: 1px solid var(--c-border);
  }
  .card h3 { font-size: var(--fs-xl); margin-bottom: 0.5rem; }
  .card p { font-size: var(--fs-base); }

  .split { display: grid; grid-template-columns: 1fr; gap: var(--space-5); }
  @media (min-width: 900px) { .split { grid-template-columns: 1fr 1fr; gap: var(--space-7); align-items: start; } }
</style>
