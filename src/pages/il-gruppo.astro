---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';

const brands = [
  { code: 'TSV', name: 'TriesteVillas', tag: 'Flagship lusso', body: 'Vendite top di gamma a Trieste e nel Friuli-Venezia Giulia. Buyer internazionali, immobili storici, ville costiere, attici di rappresentanza.', href: 'https://www.triestevillas.com' },
  { code: 'TSI', name: 'TriesteImmobiliare', tag: 'Mid-budget · agenzia smart', body: 'Il brand che stai leggendo. Vendita e acquisto residenziale, marketing curato, 0% al venditore, mandato 3 mesi.', href: '/', current: true },
  { code: 'TA', name: 'TriesteAffitti', tag: 'Affitti flessibili 1-18 mesi', body: 'Contratti transitori, foresteria, residenze temporanee. Coordinato con la vendita per la strategia "affitta mentre vendi".', href: 'https://www.triesteaffitti.com' },
  { code: 'FV', name: 'FriuliVillas', tag: 'Spin-off territoriale', body: 'Inventario in espansione sul territorio friulano. Referente: Antonella.', href: 'https://www.friulivillas.com' },
  { code: 'LV', name: 'LignanoVillas', tag: 'Spin-off territoriale', body: 'Inventario in espansione su Lignano e zona costiera.', href: 'https://www.lignanovillas.com' },
];
---
<Base
  title="Il Gruppo TriesteVillas"
  description="TriesteImmobiliare fa parte del gruppo TriesteVillas: cinque brand coordinati su lusso, mid-budget, affitti flessibili e territorio Friuli."
>
  <Hero
    eyebrow="04 · Il Gruppo"
    title={`Cinque brand,<br/>una <em>regia unica</em>.`}
    lede="TriesteImmobiliare è il brand mid-budget di un gruppo immobiliare strutturato a Trieste e nel Friuli-Venezia Giulia. Buyer network condiviso, processi comuni, specialisti dedicati per ogni segmento."
  />

  <Section pad="lg">
    <Eyebrow num="01">Brand</Eyebrow>
    <h2 style="margin-top: var(--space-2);">Tutti i brand del gruppo.</h2>
    <div class="brands">
      {brands.map((b) => (
        <a href={b.href} target={b.href.startsWith('http') ? '_blank' : '_self'} rel="noopener noreferrer" class:list={['brand', b.current && 'brand--current']}>
          <span class="brand__code">{b.code}</span>
          <div class="brand__body">
            <h3>
              {b.name}
              {b.current && <span class="brand__here">tu sei qui</span>}
            </h3>
            <p class="brand__tag">{b.tag}</p>
            <p class="brand__text">{b.body}</p>
          </div>
        </a>
      ))}
    </div>
  </Section>

  <Section variant="surface" pad="lg">
    <Eyebrow num="02">Il pivot 2020</Eyebrow>
    <h2 style="margin-top: var(--space-2); max-width: 22ch;">Dal property management turistico alle vendite.</h2>
    <div class="prose" style="margin-top: var(--space-4);">
      <p>Fino al 2020 il gruppo gestiva oltre 130 proprietà turistiche con un organico di ~30 persone. Dopo il pivot del 2020, il modello si è specializzato su due pilastri — <strong>vendite di lusso</strong> e <strong>affitti flessibili a medio termine</strong> — con un team più snello e procedure consolidate.</p>
      <p>TriesteImmobiliare è nato da quel ridisegno: stesso know-how, segmento mid-budget, processi modernizzati. Una sola provvigione, mandato breve, marketing professionale di serie.</p>
    </div>
  </Section>
</Base>

<style>
  .brands { display: grid; grid-template-columns: 1fr; gap: var(--space-3); margin-top: var(--space-5); }
  @media (min-width: 800px) { .brands { grid-template-columns: 1fr 1fr; gap: var(--space-4); } }

  .brand {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: var(--space-3);
    padding: var(--space-4);
    border: 1px solid var(--c-border);
    border-radius: var(--r-md);
    background: var(--c-bg);
    transition: border-color var(--t-fast) var(--ease), transform var(--t-fast) var(--ease), box-shadow var(--t-base) var(--ease);
    color: var(--c-ink);
  }
  .brand:hover { border-color: var(--c-primary); box-shadow: var(--shadow-2); transform: translateY(-2px); }

  .brand--current { border-color: var(--c-primary); background: var(--c-surface); }
  .brand__code {
    font-size: var(--fs-xl); font-weight: var(--fw-semibold);
    color: var(--c-primary);
    letter-spacing: var(--ls-tight);
  }
  .brand__body h3 { font-size: var(--fs-xl); margin-bottom: 0.25rem; display: inline-flex; align-items: center; gap: 0.5rem; }
  .brand__here { font-size: var(--fs-xs); text-transform: uppercase; letter-spacing: var(--ls-wider); color: var(--c-primary); font-weight: var(--fw-semibold); padding: 0.15rem 0.5rem; border: 1px solid var(--c-primary); border-radius: var(--r-pill); }
  .brand__tag { font-size: var(--fs-sm); color: var(--c-mute); font-family: var(--font-serif); font-style: italic; margin-bottom: var(--space-2); }
  .brand__text { font-size: var(--fs-base); }
</style>
