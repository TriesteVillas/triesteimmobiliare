---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Button from '../../components/Button.astro';

const sections = [
  { num: '01', eyebrow: 'Speed', title: 'Valuation in 24 hours.', body: 'Contact within 24h, on-site visit within 48, fully documented valuation within days. No promises — only timelines we hit on every mandate.' },
  { num: '02', eyebrow: 'Mandate', title: '3-month mandate. 0% to the seller.', body: 'Commission is fully on the buyer. Short mandate, renewable only if you want to. No annual lock-in.' },
  { num: '03', eyebrow: 'Marketing', title: 'Photos, video, drone, 3D tour.', body: 'Every property gets a full editorial treatment: professional photography, video, drone where useful, Matterport tour. Published on all major portals and across the TriesteVillas network.' },
  { num: '04', eyebrow: 'International', title: 'Specialists for foreign buyers.', body: 'We routinely work with Austrian, German and Slovenian buyers. Translated paperwork, notary support, end-to-end process.' },
];
---
<Base
  title="The smart agency selling homes with 0% commission to the seller"
  description="TriesteImmobiliare — selling, valuation and buying in Trieste. 3-month mandate, 0% to the seller, professional marketing, group buyer network."
>
  <Hero
    eyebrow="TriesteImmobiliare"
    title={`The <em>smart agency</em><br/>selling homes with<br/>0% to the seller.`}
    lede="3-month mandate. 24-hour valuation. Photos, video, 3D tour included. One commission — paid by the buyer."
    full
  >
    <div style="margin-top: var(--space-4); display: flex; gap: var(--space-2); flex-wrap: wrap;">
      <Button href="/en/valuation" variant="primary" size="lg">Request valuation</Button>
      <Button href="/en/sell" variant="outline" size="lg">How we sell</Button>
    </div>
  </Hero>

  {sections.map((s, i) => (
    <Section variant={i % 2 === 0 ? 'default' : 'surface'} pad="lg">
      <div class="row">
        <div>
          <Eyebrow num={s.num}>{s.eyebrow}</Eyebrow>
          <h2 class="row__title">{s.title}</h2>
        </div>
        <p class="row__body">{s.body}</p>
      </div>
    </Section>
  ))}
</Base>

<style>
  .row { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 800px) { .row { grid-template-columns: 5fr 6fr; gap: var(--space-6); align-items: start; } }
  .row__title { font-size: var(--fs-3xl); margin-top: var(--space-2); max-width: 16ch; }
  .row__body { font-size: var(--fs-lg); line-height: var(--lh-relaxed); }
</style>
