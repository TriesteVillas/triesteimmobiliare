---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Eyebrow from '../components/Eyebrow.astro';
import FormPlaceholder from '../components/FormPlaceholder.astro';

const formulas = [
  { name: 'Flex', period: '1–18 mesi', body: 'Contratto transitorio gestito da TriesteAffitti. Massima flessibilità: appena trovi l\'acquirente, esci.' },
  { name: '3 + 2', period: 'medio termine', body: 'Contratto standard locazione abitativa. Cedolare secca, rendita stabile.' },
  { name: 'Foresteria', period: 'aziendale', body: 'Per professionisti e aziende in trasferta. Yield più alto, durate compatibili con la vendita.' },
];
---
<Base
  title="Affitta mentre vendi"
  description="Strategia ibrida: vendi la casa con TriesteImmobiliare e nel frattempo la affitti con TriesteAffitti. Coordinamento unificato, rendita immediata."
>
  <Hero
    eyebrow="05 · Strategia ibrida"
    title={`<em>Affitta</em> mentre vendi.`}
    lede="La vendita di un immobile richiede tempo. Nel frattempo puoi avere reddito da locazione, mantenendo la possibilità di vendere appena emerge il match giusto."
  />

  <Section pad="lg">
    <Eyebrow num="01">Formule</Eyebrow>
    <h2 style="margin-top: var(--space-2);">Tre tipologie di contratto.</h2>
    <div class="grid">
      {formulas.map((f) => (
        <div class="card">
          <h3>{f.name}</h3>
          <p class="card__period">{f.period}</p>
          <p>{f.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section variant="surface" pad="lg">
    <Eyebrow num="02">Regia unica</Eyebrow>
    <h2 style="margin-top: var(--space-2); max-width: 24ch;">Vendita e affitto coordinati sotto un unico referente.</h2>
    <p class="prose" style="margin-top: var(--space-4);">
      Quando attivi la strategia ibrida, TriesteImmobiliare e TriesteAffitti lavorano sulla stessa pratica. Le visite di acquirenti potenziali sono concordate con il conduttore, le condizioni del contratto prevedono uscita anticipata per vendita, la transizione tra inquilino e nuovo proprietario è gestita senza attriti.
    </p>
    <div style="margin-top: var(--space-5);">
      <FormPlaceholder cta="Strategy session gratuita" intro="20 minuti per capire se la strategia ibrida fa per il tuo caso." />
    </div>
  </Section>
</Base>

<style>
  .grid { display: grid; grid-template-columns: 1fr; gap: var(--space-3); margin-top: var(--space-5); }
  @media (min-width: 800px) { .grid { grid-template-columns: repeat(3, 1fr); gap: var(--space-4); } }
  .card { padding: var(--space-4); background: var(--c-surface); border-radius: var(--r-md); border: 1px solid var(--c-border); }
  .card h3 { font-size: var(--fs-xl); }
  .card__period { font-size: var(--fs-sm); color: var(--c-mute); font-family: var(--font-serif); font-style: italic; margin: 0.25rem 0 var(--space-2); }
</style>
