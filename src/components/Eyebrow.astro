---
interface Props {
  num?: string;
  class?: string;
}
const { num, class: className = '' } = Astro.props;
---
<span class:list={['eyebrow', className]}>
  {num && <span class="eyebrow__num">{num}</span>}
  <slot />
</span>

<style>
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: var(--ls-wider);
    color: var(--c-secondary);
  }
  .eyebrow__num {
    color: var(--c-mute);
    font-variant-numeric: tabular-nums;
  }
  .eyebrow__num::after {
    content: '·';
    margin-left: 0.5rem;
    color: var(--c-mute);
  }
</style>
