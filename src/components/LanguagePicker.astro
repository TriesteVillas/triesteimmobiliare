---
import { locales, defaultLocale, localeMeta, type Locale } from '../i18n';
interface Props {
  current: Locale;
  pathWithoutLocale: string;
  variant?: 'inline' | 'menu';
}
const { current, pathWithoutLocale, variant = 'inline' } = Astro.props;

function localizedHref(loc: Locale): string {
  const clean = pathWithoutLocale === '/' ? '' : pathWithoutLocale;
  return loc === defaultLocale ? (clean || '/') : `/${loc}${clean}`;
}
---
<div class:list={['lang', `lang--${variant}`]}>
  {locales.map((loc) => (
    <a
      href={localizedHref(loc)}
      aria-current={loc === current ? 'true' : undefined}
      class:list={['lang__link', loc === current && 'is-active']}
      hreflang={loc}
      lang={localeMeta[loc].htmlLang}
    >
      {localeMeta[loc].code}
    </a>
  ))}
</div>

<style>
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }
  .lang__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.35rem 0.55rem;
    font-size: var(--fs-xs);
    font-weight: var(--fw-medium);
    color: var(--c-mute);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    border-radius: var(--r-sm);
    transition: color var(--t-fast) var(--ease), background var(--t-fast) var(--ease);
  }
  .lang__link:hover { color: var(--c-primary); background: var(--c-surface); }
  .lang__link.is-active {
    color: var(--c-primary);
    font-weight: var(--fw-semibold);
  }
  .lang--menu {
    flex-direction: column;
    align-items: stretch;
  }
  .lang--menu .lang__link {
    padding: 0.75rem 1rem;
    font-size: var(--fs-sm);
    text-align: left;
    justify-content: flex-start;
  }
</style>
