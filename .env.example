AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.YYYYYYYYYYYY
AIRTABLE_BASE_ID=app1ZDay9vQNU5V2u
AIRTABLE_TABLE_PROPRIETA=PROPRIETA

